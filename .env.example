# ═══════════════════════════════════════════════════════════════════════════
# Kindra — 환경 변수 **목록·형식** 안내 (이 파일은 Git 에 커밋해도 됩니다)
#
# 실제 값·비밀키는 절대 여기 넣지 마세요. 복사본을 `.env.local` 로 저장하세요.
# `.env.local` 은 `.gitignore` 의 `*.local` 규칙으로 커밋되지 않습니다.
# ═══════════════════════════════════════════════════════════════════════════
#
# 공개 vs 서버 전용
# ───────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_*  → 브라우저 번들에 포함됩니다. URL·anon 키처럼 "노출돼도 RLS로
#                  막을 수 있는 값"만 사용하세요. 비밀번호·서비스 롤·API 시크릿은
#                  절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요.
#
# 그 외 변수     → 서버(SSR, Server Actions, Route Handlers, middleware)에서만
#                  process.env 로 읽습니다. 클라이언트 컴포넌트나 브라우저로
#                  전달하지 마세요.
# ═══════════════════════════════════════════════════════════════════════════

# ─── 사이트 URL (이메일 매직링크 redirect 에 필수) ─────────────────────────
# 프로덕션 공식 URL은 현재 **https://kindra.vercel.app** 입니다. 커스텀 도메인을
# 연결하기 전까지 배포 환경에는 동일 값을 넣으세요. 슬래시 없이.
# canonical·Open Graph·metadataBase·sitemap.xml·robots.txt·구조화 데이터에 사용됩니다.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── 로케일·해외 진출 (선택) — 카카오톡 푸터 CS 등 한국 전용 UI ───────────
# 기본은 한국(ko): 카카오 채널 블록이 보입니다.
# NEXT_PUBLIC_KINDRA_LOCALE=ko
# 해외 단일 빌드 등에서 카카오를 끄려면 true
# NEXT_PUBLIC_KINDRA_IS_GLOBAL=true
# 위보다 우선하는 강제 토글(소문자): true | false
# NEXT_PUBLIC_KINDRA_SHOW_KAKAO=false

# ─── 카카오톡 채널 ───────────────────────────────────────────────────────
# 1) 채널 프로필 ID (필수 권장): pf.kakao.com/뒤, 예) _RVxdTX — 1:1 톡상담 링크에 사용
# 2) JavaScript 키: "채널 추가" SDK 전용(선택). 사이트 도메인·앱·채널이 카카오 콘솔에서 연동되어 있어야 합니다.
# 3) 1:1 채팅은 `https://pf.kakao.com/{채널ID}/chat` 로 열리며(코드), JS 키 없이도 동작할 수 있습니다.
# NEXT_PUBLIC_KAKAO_JS_KEY=
NEXT_PUBLIC_KAKAO_CHANNEL_ID=_RVxdTX

# ─── Supabase (필수) ───────────────────────────────────────────────────────
# 브라우저에도 노출되는 공개 값 — RLS 로 보호합니다. 절대 service_role 을 넣지 마세요.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Supabase Dashboard → Settings → API → anon public>

# 서버 전용 — Server Actions / Route Handler 에서만 import. Git·클라이언트 번들 금지.
# Settings → API 의 service_role secret 만 사용(anon 키와 다름). anon 을 넣으면 kindra_intakes INSERT 가 RLS 에 거절됩니다.
SUPABASE_SERVICE_ROLE_KEY=<Settings → API → service_role secret, 서버 전용>

# ─── 인테이크 /apply 보호 (선택) ─────────────────────────────────────────
# true 이면 로그인하지 않은 사용자는 /apply 접근 시 /auth/login 으로 리다이렉트됩니다.
# Supabase Auth 연동 전까지는 false 권장.
APPLY_REQUIRE_AUTH=false

# /report/* 게이트 — 매직링크 콜백 쿠키 + 로그인 세션이 있을 때만 리포트 허용. 배포 시 true 권장.
# 로컬 개발에서 샘플 리포트를 바로 열어보려면 unset 또는 false
REPORT_GATE_ENABLED=false

# 관리자 리포트 목록 (/admin/reports?pw=...) — 비어 있거나 불일치 시 404
ADMIN_PASSWORD=

# ─── 리포트 열람 알림 (api/notify-report-view) — 필요한 채널만 설정
# NOTIFY_SLACK_WEBHOOK_URL=
# NOTIFY_DISCORD_WEBHOOK_URL=
# NOTIFY_TELEGRAM_BOT_TOKEN=
# NOTIFY_TELEGRAM_CHAT_ID=

# ─── 토스페이먼츠 결제 위젯 (공개 MID) — /apply/payment 유료 영역 위젯 초기화 시 사용
# 미설정 시 코드 기본값(vkindrwnal) 사용. 위젯을 끄려면 빈 값: NEXT_PUBLIC_TOSS_MID=
# 시크릿 키는 서버 env 로만 두세요.
# NEXT_PUBLIC_TOSS_MID=vkindrwnal

# ─── 무통장 입금 안내 (/apply/payment 유료) — 서버 전용, 미설정 시 코드 기본값(우리은행·휘게타임) 사용
# BANK_TRANSFER_BANK_NAME=
# BANK_TRANSFER_ACCOUNT_NO=
# BANK_TRANSFER_ACCOUNT_HOLDER=

# ─── 전자상거래 등 사업장 고지 — 기본 사업장 주소는 코드(`lib/legal/business-info.ts`)에 있으며,
#     스테이징 등에서만 바꿀 때 `NEXT_PUBLIC_BUSINESS_PREMISES_ADDRESS`로 덮어쓸 수 있어요.
# NEXT_PUBLIC_BUSINESS_PREMISES_ADDRESS=서울특별시 … (도로명 주소 전체)
# 푸터·약관 등에 노출할 대표번호. 비우면 코드 기본값(`BUSINESS_INFO.supportPhone`, 070-7954-6468)이 쓰입니다.
# NEXT_PUBLIC_BUSINESS_PHONE=070-7954-6468

# 현재 측정 ID는 app/layout.tsx 의 Google tag 스니펫에 포함되어 있습니다.

# ─── Google Gemini (서버 전용) — Server Action `analyzeFiveDrawingsWithGemini` ─
# https://aistudio.google.com/apikey 에서 발급 (Git·클라이언트에 노출 금지)
GEMINI_API_KEY=
# 신규 키에서 gemini-2.0-flash 가 404 이면 gemini-2.5-flash 권장. 429 시 lite·1.5 등으로 교체.
GEMINI_MODEL=gemini-2.5-flash
# true/1 이면 Gemini 호출마다 [kindra:gemini:usage] JSON 로그(입력·출력 토큰). countTokens 선행 1회 포함(추가 API 호출).
# KINDRA_GEMINI_TOKEN_DEBUG=true
