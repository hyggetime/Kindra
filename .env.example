# ═══════════════════════════════════════════════════════════════════════════
# Kindra — 환경 변수 목록·형식 (비밀 값은 넣지 말고 `.env.local` 에만 두세요)
# NEXT_PUBLIC_* 는 브라우저 번들에 포함됩니다. 서비스 롤·시크릿 키는 절대 NEXT_PUBLIC_ 금지.
# ═══════════════════════════════════════════════════════════════════════════

# ─── 사이트 URL ────────────────────────────────────────────────────────────
# 슬래시 없이. 매직링크 redirect·metadataBase·sitemap 등에 사용.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── 로컬 개발: LAN 등 추가 출처 (선택) ────────────────────────────────────
# `next.config.ts` 가 개발 모드에서 사설망 패턴을 기본 허용합니다. 그 외 호스트만 쉼표로(호스트만, 포트 없음).
# ALLOWED_DEV_ORIGINS=192.168.219.103

# ─── Supabase (필수) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Dashboard → Settings → API → anon public>
SUPABASE_SERVICE_ROLE_KEY=<Dashboard → Settings → API → service_role, 서버 전용>

# ─── 카카오 (푸터·SDK) ─────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_CHANNEL_ID=_RVxdTX
# NEXT_PUBLIC_KAKAO_JS_KEY=  # 채널 추가 SDK 등 (선택)

# ─── 로케일·카카오 CS 블록 (선택) ──────────────────────────────────────────
# NEXT_PUBLIC_KINDRA_LOCALE=ko
# NEXT_PUBLIC_KINDRA_IS_GLOBAL=true
# NEXT_PUBLIC_KINDRA_SHOW_KAKAO=false

# ─── 결제 UI ───────────────────────────────────────────────────────────────
# 무통장 블록 숨김 — 토스 클라이언트 키가 있을 때만 의미 있음. true | 1 | yes
# NEXT_PUBLIC_PAYMENT_HIDE_BANK_TRANSFER=true
#
# 토스 카드·간편결제 창: `NEXT_PUBLIC_PAYMENT_SHOW_TOSS=true` 일 때만 표시. 미설정이면 숨김(배포·테스트 기본).
# 예전 `NEXT_PUBLIC_PAYMENT_HIDE_TOSS=false` 는 “표시”로 계속 동작합니다.
# NEXT_PUBLIC_PAYMENT_SHOW_TOSS=true
#
# (구) 토스 숨김 플래그 — SHOW_TOSS 가 우선. `HIDE_TOSS=false` 는 표시로 간주.
# NEXT_PUBLIC_PAYMENT_HIDE_TOSS=false
#
# 결제 복귀 origin 강제(선택) — 폰에서 localhost 로 열 때 등. 비우면 prepare 요청 Host 우선.
# NEXT_PUBLIC_PAYMENT_REDIRECT_ORIGIN=http://192.168.0.12:3000

# ─── 토스페이먼츠 (API 개별 연동 키) ───────────────────────────────────────
# NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
# TOSS_SECRET_KEY=test_sk_...
# TOSS_WIDGET_SECRET_KEY=  # 예전 이름 호환
# NEXT_PUBLIC_TOSS_MID=
# TOSS_CHECKOUT_SIGNING_SECRET=
# TOSS_WEBHOOK_URL_TOKEN=
# TOSS_WEBHOOK_VERIFY_WITH_API=true

# ─── 무통장 계좌 (선택, 미설정 시 코드 기본값) ─────────────────────────────
# BANK_TRANSFER_BANK_NAME=
# BANK_TRANSFER_ACCOUNT_NO=
# BANK_TRANSFER_ACCOUNT_HOLDER=

# ─── 신청 직후 리포트 접근 쿠키 서명 (선택) ─────────────────────────────────
# REPORT_ACCESS_SIGNING_SECRET=

# ─── /apply · 리포트 게이트 ─────────────────────────────────────────────────
APPLY_REQUIRE_AUTH=false
REPORT_GATE_ENABLED=false
ADMIN_PASSWORD=<관리자 비밀번호>

# ─── GitHub Actions / Vercel Cron: 만료 인테이크 정리 API (선택) ───────────
# CRON_SECRET=
# CLEANUP_EXPIRY_HOURS=72

# ─── 리포트 열람 알림 (`api/notify-report-view`) — 필요한 것만 ─────────────
# NOTIFY_SLACK_WEBHOOK_URL=
# NOTIFY_DISCORD_WEBHOOK_URL=
# NOTIFY_TELEGRAM_BOT_TOKEN=
# NOTIFY_TELEGRAM_CHAT_ID=

# ─── 로컬 전용 개발 플래그 ─────────────────────────────────────────────────
# KINDRA_DEV_INTAKE_BYPASS=true
# NEXT_PUBLIC_SKIP_PAYMENT_FOR_ANALYSIS=true

# ─── 사업자 고지 덮어쓰기 (선택) ───────────────────────────────────────────
# NEXT_PUBLIC_BUSINESS_PREMISES_ADDRESS=
# NEXT_PUBLIC_BUSINESS_PHONE=

# ─── 분석 (선택) ───────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxxxxxxxx
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ─── Resend 이메일 웹훅 ─────────────────────────────────────────────────────
# Dashboard → Webhooks → signing secret (`whsec_...`). 엔드포인트: /api/webhooks/resend
# RESEND_WEBHOOK_SECRET=whsec_...
# 발송 시 tags: { report_id: "<kindra_reports.uuid>" } 를 넣으면 리포트와 연결됩니다.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# KINDRA_GEMINI_TOKEN_DEBUG=true
# true|1 이면 countTokens 등 추가 API. 개발 모드에서는 터미널 사용량 로그가 기본 ON — 끄려면 false|0

# =========================================================================
# KINDRA PREMIUM 5-IMAGE STRUCTURED REPORT CONFIGURATION
# =========================================================================

# 토스 미니앱 정적 뷰어에서 루트 API로 접근할 때 허용할 CORS 오리진 주소 (로컬 테스트 시 http://localhost:3001 등)
KINDRA_STRUCTURED_REPORT_CORS_ORIGIN=http://localhost:3001

# 미니앱→메인 `POST /api/kindra-premium-intake` 인가. 설정 시 `Authorization: Bearer <값>` 일치 요청만 허용(playground 무관).
# 미니앱 Next 서버 프록시가 동일 값으로 메인을 호출합니다. channel=toss 로 기록됩니다.
# KINDRA_MINIAPP_SHARED_SECRET=

# 설치형(데스크톱) 클라이언트 → `POST` Server Action/API 시 `Authorization: Bearer <값>` 또는 `X-Kindra-Desktop-Token: <값>`
# channel=desktop 으로 kindra_reports 에 저장됩니다.
# KINDRA_DESKTOP_API_SECRET=

# 개발 및 프롬프트 실험실 프리뷰 페이지에서 실시간 Gemini 엔진 가동을 허용할지 여부 (1: 활성화, 0: 비활성화)
ALLOW_PROMPT_PLAYGROUND=1
