{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "types": ["react-native"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "index.ts",
    "_app.tsx",
    "require.context.ts",
    "granite.config.ts",
    "babel.config.js",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../lib/kindra-premium-intake-types.ts"
  ],
  "exclude": [
    "node_modules",
    "src/app",
    "src/components/flow",
    "src/components/home",
    "src/components/preview",
    "src/components/TossInAppBootstrap.tsx",
    ".next",
    "out"
  ]
}
