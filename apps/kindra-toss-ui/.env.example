NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 프리뷰 «실시간 분석» — 루트 Kindra API (기본 http://localhost:3000)
NEXT_PUBLIC_KINDRA_WEB_API_ORIGIN=http://localhost:3000

# (선택) 메인 Kindra 백엔드 베이스 URL — 비우면 KINDRA_WEB_API_ORIGIN 과 동일하게 사용
# NEXT_PUBLIC_KINDRA_API_URL=https://kindra.example.com

# 메인 웹 오리진(서버 전용) — `/api/kindra-premium-intake` 프록시가 Bearer 붙여 호출할 대상. 비우면 위 PUBLIC URL 사용.
# KINDRA_MAIN_API_ORIGIN=http://localhost:3000

# 메인·미니앱 동일 값. 미니앱 서버 프록시가 메인 API Authorization Bearer 로 전달합니다.
# KINDRA_MINIAPP_SHARED_SECRET=

# Toss Payments — 브라우저 클라이언트 키 (미니앱 프리미엄 결제)
# NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=test_ck_...

# 루트 앱 `.env.local` 에는 브라우저가 미니앱을 연 오리진과 동일하게 설정하세요.
# 예: KINDRA_STRUCTURED_REPORT_CORS_ORIGIN=http://localhost:3001
#     ALLOW_PROMPT_PLAYGROUND=1
