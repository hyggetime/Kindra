NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 프리뷰 «실시간 분석» — 루트 Kindra API (기본 http://localhost:3000)
NEXT_PUBLIC_KINDRA_WEB_API_ORIGIN=http://localhost:3000

# 루트 앱 `.env.local` 에는 브라우저가 미니앱을 연 오리진과 동일하게 설정하세요.
# 예: KINDRA_STRUCTURED_REPORT_CORS_ORIGIN=http://localhost:3001
#     ALLOW_PROMPT_PLAYGROUND=1
